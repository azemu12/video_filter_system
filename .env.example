OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 数据库配置
DB_TYPE=sqlite
DB_SQLITE_PATH=./videos.db
DB_TABLE_NAME=videos
DB_FILE_PATH_COLUMN=file_path
VIDEO_ROOT_DIR=

# 视频筛选
LANDSCAPE_RATIO=1.5
MIN_WIDTH=1280
MIN_HEIGHT=720

# 抽帧配置
FRAME_STRATEGY=uniform
FRAME_FPS=1.0
MAX_FRAMES=30
FRAME_FORMAT=jpg
FRAME_QUALITY=85

# 质量分析
MIN_SHARPNESS=0.3
MIN_BRIGHTNESS=0.1
MAX_BRIGHTNESS=0.95
MIN_CONTRAST=0.1

# YOLO配置
YOLO_MODEL=yolov8x.pt
YOLO_CONFIDENCE=0.5

# MediaPipe
MEDIAPIPE_ENABLED=true

# 评分阈值
MIN_USABILITY_SCORE=60
MAX_PER_CATEGORY=100

# 存储配置
COPY_VIDEOS=false
SYMLINK_VIDEOS=true

# 日志
LOG_LEVEL=INFO
